{
  "name": "Cataclysm Arcade",
  "menuBackgroundImage": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/background.jpg",
  "defaultRessources": {
    "backgrounds": [
      "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/playmat.webp",
      "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/playmat2.webp"
    ],
    "decksUrl": "https://balbi.github.io/TCGA-Cataclysm-Arcade/CataclysmArcade_Decks.json"
  },
  "customHelp": "",
  "cardRotation": "90",
  "cards": {
    "dataUrl": "https://balbi.github.io/TCGA-Cataclysm-Arcade/CataclysmArcade_Cards.json",
    "cardBack": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/cardback.png"
  },
  "deckBuilding": {
    "mainFilters": [
      "type",
      "Subtype",
      "Faction",
      "Set",
      "Level",
      "Health",
      "Attack",
      "AttackCost",
      "WeaponLevel",
      "WeaponWieldCost",
      "WeaponAttackCost",
      "Rarity"
    ],
    "formats": [
      {
        "title": "Constructed",
        "gameplay": "Standard",
        "deckRuleset": "Constructed",
        "customCategories": [
          "Boss"
        ]
      }
    ],
    "deckRulesets": {
      "Constructed": {
        "reversedLegality": true,
        "general": {
          "min": 41,
          "maxPerCard": 3
        },
        "categories": [
          {
            "category": "Boss",
            "min": 1,
            "max": 1
          }
        ]
      }
    }
  },
  "gameplay": {
    "Standard": {
      "mulligan": {
        "triggeredByButton": true,
        "startingHandSize": 4,
        "mulliganCount": {
          "min": 0,
          "max": 1
        },
        "mulliganCycle": {
          "info": "Set aside any number of cards in your initial hand, draw that many, then shuffle the set aside cards into your deck.",
          "steps": [
            "toBottom",
            "draw",
            "shuffle"
          ],
          "selectionRange": {
            "min": 0,
            "max": 4
          },
          "keepCardsOrder": true
        }
      },
      "newTurn": {
        "drawOnStart": true,
        "sharedTurn": true,
        "firstPlayerTokenName": "",
        "drawPerTurn": "1"
      },
      "tokens": [],
      "countersStartingValues": [
        0
      ],
      "hideFacedDownCards": false,
      "sections": {
        "layout": {
          "direction": "column",
          "isSymetricalForOpponents": false,
          "style": {
            "marginTop": "4vh"
          },
          "content": [
            {
              "section": "Scoreboard"
            },
            {
              "section": "Controls"
            },
            {
              "direction": "row",
              "isSymetricalForOpponents": false,
              "content": [
                {
                  "section": "Boss",
                  "style": {
                    "width": "11vh"
                  }
                }
              ]
            },
            {
              "section": "Battlefield"
            }
          ]
        },
        "categoriesAlreadyOnBoard": [
          "Boss"
        ],
        "autoPlayFromHand": {},
        "autoPlayFromStack": {},
        "sectionsDict": {
          "Boss": {
            "isHidden": "no",
            "height": "SMALL",
            "alignment": "CENTER",
            "opponentAlignment": false,
            "noAutoPayTo": "true",
            "isHorizontalAllowed": false,
            "enterTapped": false,
            "enterSpun": false,
            "isGroupForbidden": false,
            "keepTappedNewTurn": false,
            "showHiddenCardInHistory": false,
            "noQuickActions": true
          },
          "Battlefield": {
            "isHidden": "no",
            "height": "SMALL",
            "alignment": "END",
            "opponentAlignment": false,
            "noAutoPayTo": true,
            "isHorizontalAllowed": false,
            "noQuickActions": true,
            "enterTapped": false,
            "enterSpun": false,
            "isGroupForbidden": false,
            "keepTappedNewTurn": false,
            "showHiddenCardInHistory": false
          },
          "Scoreboard": {
            "type": "custom",
            "playerRenderOnly": true,
            "blueprint": {
              "type": "div",
              "props": {
                "className": "d-flex flex-row justify-content-between position-fixed start-50 top-50 translate-middle",
                "style": {
                  "--scoreboard-width": "7vh",
                  "--scoreboard-font-weight": "900",
                  "--scoreboard-font-size": "1.7vh",
                  "--scoreboard-blue": "#64bfe3",
                  "--scoreboard-red": "#d83938",
                  "--scoreboard-opacity": "0.3",
                  "--scoreboard-padding": "0.7vh 0",
                  "--input-color-empty": "transparent",
                  "height": "7vh",
                  "backdropFilter": "blur(20px)",
                  "padding": "0.5vh",
                  "backgroundColor": "#202020c9",
                  "borderRadius": "0.5vh",
                  "marginLeft": "var(--left-offset-centered)"
                }
              },
              "children": [
                {
                  "type": "img",
                  "props": {
                    "style": {
                      "height": "100%"
                    },
                    "src": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/level_{{ Math.max(game.data.Scoreboard.level, 1) }}.png"
                  }
                },
                {
                  "type": "loop",
                  "iterable": "game.data.Scoreboard.players",
                  "template": {
                    "type": "div",
                    "props": {
                      "className": "flex-column justify-content-between",
                      "style": {
                        "height": "100%",
                        "padding": "0 1vh",
                        "display": "{{ item.index < game.turn.totalPlayers ? 'flex' : 'none' }}"
                      }
                    },
                    "children": [
                      {
                        "type": "div",
                        "children": "Player {{ item.index + 1 }}"
                      },
                      {
                        "type": "div",
                        "props": {
                          "className": "d-flex flex-row justify-content-around",
                          "style": {
                            "height": "3vh",
                            "width": "7vh"
                          }
                        },
                        "children": [
                          {
                            "type": "img",
                            "props": {
                              "style": {
                                "height": "100%"
                              },
                              "src": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/token_{{ item.tokens }}.png"
                            }
                          },
                          {
                            "type": "img",
                            "props": {
                              "style": {
                                "height": "100%"
                              },
                              "src": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/{{ item.passed ? 'red' : 'green' }}.png"
                            }
                          }
                        ]
                      }
                    ]
                  }
                }
              ]
            },
            "defaultValue": {
              "level": 0,
              "turnPlayerIndex": 0,
              "players": [
                {
                  "tokens": 0,
                  "health": 0,
                  "passed": false,
                  "index": 0
                },
                {
                  "tokens": 0,
                  "health": 0,
                  "passed": false,
                  "index": 1
                },
                {
                  "tokens": 0,
                  "health": 0,
                  "passed": false,
                  "index": 2
                },
                {
                  "tokens": 0,
                  "health": 0,
                  "passed": false,
                  "index": 3
                }
              ]
            },
            "events": {
              "onStart": "console.log('Scoreboard: onStart'); console.log(game);",
              "onUpdate": "console.log('Scoreboard: onUpdate'); console.log(game);",
              "onNewTurn": "console.log('Scoreboard: onNewTurn'); const gs = game.data.Scoreboard; gs.level = Math.min(Math.max(game.turn.count, 1), 9); const gc = game.data.Controls; gc.tokens = gs.level; gc.passed = false; for(const player of gs.players){ player.tokens = gs.level; player.passed = false; }; console.log(game);",
              "onOpponentUpdate": "console.log('Scoreboard: onOpponentUpdate'); const gs = game.data.Scoreboard; const ogs = opponentGame.data.Scoreboard; if( ogs.turnPlayerIndex > gs.turnPlayerIndex){ gs.turnPlayerIndex = ogs.turnPlayerIndex; }; console.log(game, opponentGame);"
            }
          },
          "Controls": {
            "type": "custom",
            "playerRenderOnly": true,
            "blueprint": {
              "type": "div",
              "props": {
                "className": "controls"
              },
              "children": [
                {
                  "type": "div",
                  "props": {
                    "className": "flex-column justify-content-center position-fixed end-0 top-50",
                  "style": {
                    "--scoreboard-width": "6vh",
                    "--scoreboard-font-weight": "700",
                    "--scoreboard-font-size": "1.7vh",
                    "--scoreboard-opacity": "0.3",
                    "--scoreboard-padding": "0.7vh 0",
                    "--input-color-empty": "transparent",
                    "height": "31.5vh",
                    "width": "23.5vh",
                    "backdropFilter": "blur(20px)",
                    "padding": "0.5vh",
                    "backgroundColor": "#202020c9",
                    "borderRadius": "0.5vh",
                    "display": "{{ (game.data.Scoreboard.turnPlayerIndex % game.turn.totalPlayers) == game.turn.orderPosition ? 'flex' : 'none' }}"
                  }
                  },
                  "children": [
                    {
                      "type": "h1",
                      "children": [
                        "Your Turn!"
                      ]
                    },
                    {
                      "type": "div",
                      "children":[
                        "Health: {{ game.data.Controls.health }}"
                      ]
                    },
                    {
                      "type": "div",
                      "children": [
                        "Tokens: {{ game.data.Controls.tokens }}"
                      ]
                    },
                    {
                      "type": "div",
                      "children": [
                        "Passed: {{ game.data.Controls.passed }}"
                      ]
                    },
                    {
                      "type": "button",
                      "props":{
                        "className": "{{ game.data.Controls.passed ? 'disabled ' : '' }}"
                      },
                      "children": "Pass",
                      "onClick": "game.data.Controls.passed = true; game.data.Scoreboard.players[game.turn.orderPosition].passed = true; chatLog('has passed.')"
                    },
                    {
                      "type": "button",
                      "props":{
                        "className": "{{ game.data.Controls.passed ? 'disabled ' : '' }}"
                      },
                      "children": "Next",
                      "onClick": "let TPI = game.data.Scoreboard.turnPlayerIndex + 1; for(let i = 0; i < game.turn.totalPlayers; i++){ if(!game.data.Scoreboard.players[TPI % game.turn.totalPlayers].passed){ game.data.Scoreboard.turnPlayerIndex = TPI; break; } TPI++; }; chatLog('has ended their action.')"
                    }
                  ]
                }
              ]
            },
            "defaultValue": {
              "health": 0,
              "tokens": 0,
              "passed": false
            },
            "events": {
              "onStart": "console.log('Controls: onStart', game); console.log(game);",
              "onOpponentUpdate": "console.log('Controls: onOpponentUpdate', game, opponentGame); const ogc = opponentGame.data.Controls; const ogs = game.data.Scoreboard.players[opponentGame.turn.orderPosition]; ogs.health = ogc.health; ogs.tokens = ogc.tokens; ogs.passed = ogc.passed;",
              "onNewTurn": "console.log('Controls: onNewTurn', game); console.log(game);"
            }
          }
        }
      }
    }
  }
}