{
  "name": "Cataclysm Arcade",
  "menuBackgroundImage": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/background.jpg",
  "defaultRessources": {
    "backgrounds": [
      "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/playmat.webp",
      "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/playmat2.webp"
    ],
    "decksUrl": "https://balbi.github.io/TCGA-Cataclysm-Arcade/CataclysmArcade_Decks.json"
  },
  "customHelp": "",
  "cardRotation": "90",
  "cards": {
    "dataUrl": "https://balbi.github.io/TCGA-Cataclysm-Arcade/CataclysmArcade_Cards.json",
    "cardBack": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/cardback.png"
  },
  "deckBuilding": {
    "mainFilters": [
      "type",
      "Subtype",
      "Faction",
      "Set",
      "Level",
      "Health",
      "Attack",
      "AttackCost",
      "WeaponLevel",
      "WeaponWieldCost",
      "WeaponAttackCost",
      "Rarity"
    ],
    "formats": [
      {
        "title": "Constructed",
        "gameplay": "Standard",
        "deckRuleset": "Constructed",
        "customCategories": [
          "Boss"
        ]
      }
    ],
    "deckRulesets": {
      "Constructed": {
        "reversedLegality": true,
        "general": {
          "min": 41,
          "maxPerCard": 3
        },
        "categories": [
          {
            "category": "Boss",
            "min": 1,
            "max": 1
          }
        ]
      }
    }
  },
  "gameplay": {
    "Standard": {
      "mulligan": {
        "triggeredByButton": true,
        "startingHandSize": 4,
        "mulliganCount": {
          "min": 0,
          "max": 1
        },
        "mulliganCycle": {
          "info": "Set aside any number of cards in your initial hand, draw that many, then shuffle the set aside cards into your deck.",
          "steps": [
            "toBottom",
            "draw",
            "shuffle"
          ],
          "selectionRange": {
            "min": 0,
            "max": 4
          },
          "keepCardsOrder": true
        }
      },
      "newTurn": {
        "drawOnStart": true,
        "sharedTurn": true,
        "firstPlayerTokenName": "",
        "drawPerTurn": "1"
      },
      "tokens": [],
      "countersStartingValues": [
        0
      ],
      "hideFacedDownCards": false,
      "sections": {
        "layout": {
          "direction": "column",
          "isSymetricalForOpponents": false,
          "style": {
            "marginTop": "4vh"
          },
          "content": [
            {
              "section": "Scoreboard"
            },
            {
              "section": "Controls"
            },
            {
              "direction": "row",
              "isSymetricalForOpponents": false,
              "alignment": "CENTER",
              "content": [
                {
                  "section": "Boss",
                  "style": {
                    "width": "16vh"
                  }
                }
              ]
            },
            {
              "section": "Battlefield"
            }
          ]
        },
        "categoriesAlreadyOnBoard": [
          "Boss"
        ],
        "autoPlayFromHand": {},
        "autoPlayFromStack": {},
        "sectionsDict": {
          "Boss": {
            "isHidden": "no",
            "height": "SMALL",
            "alignment": "CENTER",
            "opponentAlignment": false,
            "noAutoPayTo": "true",
            "isHorizontalAllowed": false,
            "enterTapped": false,
            "enterSpun": false,
            "isGroupForbidden": false,
            "keepTappedNewTurn": false,
            "showHiddenCardInHistory": false,
            "noQuickActions": true
          },
          "Battlefield": {
            "isHidden": "no",
            "height": "SMALL",
            "alignment": "END",
            "opponentAlignment": false,
            "noAutoPayTo": true,
            "isHorizontalAllowed": false,
            "noQuickActions": true,
            "enterTapped": false,
            "enterSpun": false,
            "isGroupForbidden": false,
            "keepTappedNewTurn": false,
            "showHiddenCardInHistory": false
          },
          "Scoreboard": {
            "type": "custom",
            "isShared": true,
            "blueprint": {
              "type": "div",
              "props": {
                "className": "d-flex flex-row justify-content-between position-fixed start-50 top-50 translate-middle",
                "style": {
                  "--scoreboard-width": "6vh",
                  "--scoreboard-font-weight": "700",
                  "--scoreboard-font-size": "1.7vh",
                  "--scoreboard-blue": "#64bfe3",
                  "--scoreboard-red": "#d83938",
                  "--scoreboard-opacity": "0.3",
                  "--scoreboard-padding": "0.7vh 0",
                  "--input-color-empty": "transparent",
                  "height": "7vh",
                  "width": "50vh",
                  "backdropFilter": "blur(20px)",
                  "padding": "0.5vh",
                  "backgroundColor": "#202020c9",
                  "borderRadius": "0.5vh",
                  "marginLeft": "var(--left-offset-centered)"
                }
              }
            },
            "defaultValue": {
              "level": 0,
              "turnPlayerIndex": 0,
              "players": []
            },
            "events": {
              "onStart": "if(game.data.Scoreboard.players.length == 0){for(let i = 0; i < game.turn.totalPlayers; i++){game.data.Scoreboard.players[i] = { tokens: 0, health: 0, passed: false };};};",
              "onNewTurn": "game.data.Scoreboard.level = Math.min(game.data.Scoreboard.level + 1, 9); for(let i = 0; i < game.turn.totalPlayers; i++){game.data.Scoreboard.players[i].tokens = game.data.Scoreboard.level; game.data.Scoreboard.players[i].passed = false;}; game.data.Controls.tokens = game.data.Scoreboard.level;  console.log('GAME DATA');console.log(game);"
            },
            "children": [
              {
                "type": "img",
                "props": {
                  "style": {
                    "height": "100%"
                  }
                },
                "src": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/level_{{ game.data.Scoreboard.level }}.png"
              },
              {
                "type": "loop",
                "iterable": "game.data.Scoreboard.players",
                "template": {
                  "type": "div",
                  "props": {
                    "className": "d-flex flex-column justify-content-between",
                    "style": {
                      "height": "100%"
                    }
                  }
                },
                "children": [
                  {
                    "type": "div",
                    "display": "Player {{ index + 1 }}"
                  },
                  {
                    "type": "div",
                    "props": {
                      "className": "d-flex flex-row justify-content-around",
                      "style": {
                        "aspect-ratio": "1"
                      }
                    },
                    "children": [
                      {
                        "type": "img",
                        "props": {
                          "style": {
                            "height": "100%"
                          }
                        },
                        "src": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/token_{{ item?.tokens }}.png"
                      },
                      {
                        "type": "img",
                        "props": {
                          "style": {
                            "height": "100%"
                          }
                        },
                        "src": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/{{ item?.passed ? 'next' : 'pass' }}.png"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          "Controls": {
            "type": "custom",
            "blueprint": {
              "type": "div",
              "props": {
                "className": "controls"
              }
            },
            "defaultValue": {
              "health": 0,
              "tokens": 0,
              "passed": false
            },
            "events": {
              "onOpponentUpdate": "const dc = opponentGame.data.Controls; game.data.Scoreboard.players?.[opponentGame.turn.orderPosition]?.tokens = dc.tokens; game.data.Scoreboard.players?.[opponentGame.turn.orderPosition]?.health = dc.health; game.data.Scoreboard.players?.[opponentGame.turn.orderPosition]?.passed = dc.passed;",
              "onNewTurn": ""
            },
            "children": [
              {
                "type": "div",
                "props": {
                  "className": "d-flex flex-column justify-content-between position-fixed end top-50 translate-middle"
                },
                "style": {
                  "--scoreboard-width": "6vh",
                  "--scoreboard-font-weight": "700",
                  "--scoreboard-font-size": "1.7vh",
                  "--scoreboard-opacity": "0.3",
                  "--scoreboard-padding": "0.7vh 0",
                  "--input-color-empty": "transparent",
                  "height": "8vh",
                  "width": "16vh",
                  "backdropFilter": "blur(20px)",
                  "padding": "0.5vh",
                  "backgroundColor": "#202020c9",
                  "borderRadius": "0.5vh",
                  "marginLeft": "var(--left-offset-centered)"
                },
                "children": [
                  {
                    "type": "div",
                    "display": "Health: {{ game.data.Controls.health }}"
                  },
                  {
                    "type": "div",
                    "display": "Tokens: {{ game.data.Controls.tokens }}"
                  },
                  {
                    "type": "div",
                    "display": "Passed: {{ game.data.Controls.passed }}"
                  },
                  {
                    "type": "button",
                    "children": "Pass",
                    "onClick": "game.data.Controls.passed = true; chatLog('has passed.')"
                  }
                ]
              }
            ]
          }
        }
      }
    }
  }
}