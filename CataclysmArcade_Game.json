{
  "name": "Cataclysm Arcade",
  "menuBackgroundImage": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/background.jpg",
  "defaultRessources": {
    "backgrounds": [
      "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/playmat.webp",
      "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/playmat2.webp"
    ],
    "decksUrl": "https://balbi.github.io/TCGA-Cataclysm-Arcade/CataclysmArcade_Decks.json"
  },
  "customHelp": "",
  "cardRotation": "90",
  "cards": {
    "dataUrl": "https://balbi.github.io/TCGA-Cataclysm-Arcade/CataclysmArcade_Cards.json",
    "cardBack": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/cardback.png"
  },
  "deckBuilding": {
    "mainFilters": [
      "type",
      "Subtype",
      "Faction",
      "Set",
      "Level",
      "Health",
      "Attack",
      "AttackCost",
      "WeaponLevel",
      "WeaponWieldCost",
      "WeaponAttackCost",
      "Rarity"
    ],
    "formats": [
      {
        "title": "Constructed",
        "gameplay": "Standard",
        "deckRuleset": "Constructed",
        "customCategories": [
          "Boss"
        ]
      }
    ],
    "deckRulesets": {
      "Constructed": {
        "reversedLegality": true,
        "general": {
          "min": 41,
          "maxPerCard": 3
        },
        "categories": [
          {
            "category": "Boss",
            "min": 1,
            "max": 1
          }
        ]
      }
    }
  },
  "gameplay": {
    "Standard": {
      "mulligan": {
        "triggeredByButton": true,
        "startingHandSize": 4,
        "mulliganCount": {
          "min": 0,
          "max": 1
        },
        "mulliganCycle": {
          "info": "Set aside any number of cards in your initial hand, draw that many, then shuffle the set aside cards into your deck.",
          "steps": [
            "toBottom",
            "draw",
            "shuffle"
          ],
          "selectionRange": {
            "min": 0,
            "max": 4
          },
          "keepCardsOrder": true
        }
      },
      "newTurn": {
        "drawOnStart": true,
        "sharedTurn": true,
        "firstPlayerTokenName": "",
        "drawPerTurn": "1"
      },
      "tokens": [],
      "countersStartingValues": [
        0
      ],
      "hideFacedDownCards": false,
      "sections": {
        "layout": {
          "direction": "column",
          "isSymetricalForOpponents": false,
          "style": {
            "marginTop": "2vh"
          },
          "content": [
            {
              "section": "Scoreboard"
            },
            {
              "direction": "row",
              "isSymetricalForOpponents": false,
              "style": {
                "justify-content": "center",
                "padding": "0 20vh"
              },
              "content": [
                {
                  "section": "Boss",
                  "style": {
                    "width": "16vh"
                  }
                },
                {
                  "section": "Controls"
                }
              ]
            },
            {
              "section": "Battlefield"
            }
          ]
        },
        "categoriesAlreadyOnBoard": [
          "Boss"
        ],
        "autoPlayFromHand": {},
        "autoPlayFromStack": {},
        "sectionsDict": {
          "Boss": {
            "isHidden": "no",
            "height": "MEDIUM",
            "alignment": "CENTER",
            "opponentAlignment": false,
            "noAutoPayTo": "true",
            "isHorizontalAllowed": false,
            "enterTapped": false,
            "enterSpun": false,
            "isGroupForbidden": false,
            "keepTappedNewTurn": false,
            "showHiddenCardInHistory": false,
            "noQuickActions": true
          },
          "Battlefield": {
            "isHidden": "no",
            "height": "SMALL",
            "alignment": "END",
            "opponentAlignment": false,
            "noAutoPayTo": true,
            "isHorizontalAllowed": false,
            "noQuickActions": true,
            "enterTapped": false,
            "enterSpun": false,
            "isGroupForbidden": false,
            "keepTappedNewTurn": false,
            "showHiddenCardInHistory": false
          },
          "Scoreboard": {
            "type": "custom",
            "isShared": true,
            "blueprint": {
              "type": "div",
              "props": {
                "className": "d-flex flex-row justify-content-between position-fixed start-50 top-50 translate-middle",
                "style": {
                  "--scoreboard-width": "7vh",
                  "--scoreboard-font-weight": "900",
                  "--scoreboard-font-size": "1.7vh",
                  "--scoreboard-blue": "#64bfe3",
                  "--scoreboard-red": "#d83938",
                  "--scoreboard-opacity": "0.3",
                  "--scoreboard-padding": "0.7vh 0",
                  "--input-color-empty": "transparent",
                  "height": "7vh",
                  "backdropFilter": "blur(20px)",
                  "padding": "0.5vh",
                  "backgroundColor": "#202020c9",
                  "borderRadius": "0.5vh",
                  "marginLeft": "var(--left-offset-centered)"
                }
              },
              "children": [
                {
                  "type": "img",
                  "props": {
                    "style": {
                      "height": "100%"
                    },
                    "src": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/level_{{ Math.max(game.data.Scoreboard.level, 1) }}.png"
                  }
                },
                {
                  "type": "loop",
                  "iterable": "game.data.Scoreboard.players",
                  "template": {
                    "type": "div",
                    "props": {
                      "className": "flex-column justify-content-between",
                      "style": {
                        "height": "100%",
                        "padding": "0 1vh",
                        "display": "{{ item.index < game.turn.totalPlayers ? 'flex' : 'none' }}"
                      }
                    },
                    "children": [
                      {
                        "type": "div",
                        "children": "Player {{ item.index + 1 }}"
                      },
                      {
                        "type": "div",
                        "props": {
                          "className": "d-flex flex-row justify-content-around",
                          "style": {
                            "height": "3vh",
                            "width": "12vh"
                          }
                        },
                        "children": [
                          {
                            "type": "div",
                            "props": {
                              "style": {
                                "position": "relative",
                                "height": "100%",
                                "width": "3vh"
                              }
                            },
                            "children": [
                              {
                                "type": "img",
                                "props": {
                                  "style": {
                                    "height": "100%"
                                  },
                                  "src": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/health_blank.png"
                                }
                              },
                              {
                                "type": "div",
                                "props": {
                                  "style": {
                                    "top": "0.075vh",
                                    "position": "absolute",
                                    "height": "100%",
                                    "width": "100%",
                                    "color": "white",
                                    "font-weight": "bold",
                                    "display": "flex",
                                    "align-items": "center",
                                    "justify-content": "center"
                                  }
                                },
                                "children": [
                                  {
                                    "type": "span",
                                    "props": {
                                      "style": {
                                        "text-shadow": "-1px -1px 0 #000, 1px -1px 0 #000,-1px  1px 0 #000, 1px  1px 0 #000",
                                        "font-size": "2.25vh"
                                      }
                                    },
                                    "children": "{{ Math.max(item.health, 0) }}"
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "type": "img",
                            "props": {
                              "style": {
                                "height": "100%"
                              },
                              "src": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/token_{{ item.tokens }}.png"
                            }
                          },
                          {
                            "type": "img",
                            "props": {
                              "style": {
                                "height": "100%"
                              },
                              "src": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/{{ item.passed ? 'red' : 'green' }}.png"
                            }
                          }
                        ]
                      }
                    ]
                  }
                }
              ]
            },
            "defaultValue": {
              "level": 0,
              "turnPlayerIndex": 0,
              "startingPlayer": 0,
              "players": [
                {
                  "tokens": 0,
                  "health": 0,
                  "passed": false,
                  "index": 0
                },
                {
                  "tokens": 0,
                  "health": 0,
                  "passed": false,
                  "index": 1
                },
                {
                  "tokens": 0,
                  "health": 0,
                  "passed": false,
                  "index": 2
                },
                {
                  "tokens": 0,
                  "health": 0,
                  "passed": false,
                  "index": 3
                }
              ]
            },
            "events": {
              "onStart": "console.log('Scoreboard: onStart'); console.log(game);",
              "onUpdate": "console.log('Scoreboard: onUpdate'); console.log(game);",
              "onNewTurn": "console.log('Scoreboard: onNewTurn'); game.data.Scoreboard.level = Math.min(Math.max(game.turn.count, 1), 9); game.data.Controls.tokens = game.data.Scoreboard.level; game.data.Controls.passed = false; const gs = game.data.Scoreboard; for(const player of gs.players){ player.tokens = gs.level; player.passed = false; }; console.log(game);",
              "onOpponentUpdate": "console.log('Scoreboard: onOpponentUpdate'); const gs = game.data.Scoreboard; const ogs = opponentGame.data.Scoreboard; if( ogs.turnPlayerIndex > gs.turnPlayerIndex){ gs.turnPlayerIndex = ogs.turnPlayerIndex; }; console.log(game, opponentGame);"
            }
          },
          "Controls": {
            "type": "custom",
            "playerRenderOnly": true,
            "blueprint": {
              "type": "div",
              "props": {
                "className": "controls"
              },
              "children": [
                {
                  "type": "div",
                  "props": {
                    "className": "flex-column justify-content-right position-fixed top-50",
                    "style": {
                      "--scoreboard-width": "6vh",
                      "--scoreboard-font-weight": "700",
                      "--scoreboard-font-size": "1.7vh",
                      "--scoreboard-opacity": "0.3",
                      "--scoreboard-padding": "0.7vh 0",
                      "--input-color-empty": "transparent",
                      "width": "16vh",
                      "height": "20vh",
                      "right": "31.5vh",
                      "backdropFilter": "blur(20px)",
                      "padding": "1.5vh",
                      "backgroundColor": "#202020c9",
                      "borderRadius": "0.5vh",
                      "display": "{{ (game.data.Scoreboard.turnPlayerIndex % game.turn.totalPlayers) == game.turn.orderPosition && game.turn.count > 0 ? 'flex' : 'none' }}"
                    }
                  },
                  "children": [
                    {
                      "type": "h4",
                      "children": [
                        "Your Turn!"
                      ]
                    },
                    {
                      "type": "div",
                      "props": {
                        "className": "d-flex flex-row justify-content-center"
                      },
                      "children": [
                        {
                          "type": "h4",
                          "children": [
                            "Health"
                          ]
                        },
                        {
                          "type": "input-number",
                          "props": {
                            "value": "{{ game.data.Controls.health }}",
                            "type": "number",
                            "style": {
                              "width": "4vh",
                              "textAlign": "center"
                            }
                          },
                          "onChange": "game.data.Controls.health = +value; chatLog('has updated their health to ' + value)"
                        }
                      ]
                    },
                    {
                      "type": "div",
                      "props": {
                        "className": "d-flex flex-row justify-content-center"
                      },
                      "children": [
                        {
                          "type": "h4",
                          "children": [
                            "Tokens"
                          ]
                        },
                        {
                          "type": "input-number",
                          "props": {
                            "value": "{{ game.data.Controls.tokens }}",
                            "type": "number",
                            "style": {
                              "width": "4vh",
                              "textAlign": "center"
                            }
                          },
                          "onChange": "game.data.Controls.tokens = +value; chatLog('has updated their tokens to ' + value)"
                        }
                      ]
                    },
                    {
                      "type": "div",
                      "props": {
                        "className": "d-flex flex-row justify-content-around"
                      },
                      "children": [
                        {
                          "type": "button",
                          "props": {
                            "className": "{{ game.data.Controls.passed ? 'disabled ' : '' }}",
                            "style": {
                              "width": "5vh",
                              "height": "5vh",
                              "background": "none",
                              "border": "none",
                              "padding": "0",
                              "cursor": "pointer",
                              "outline": "none"
                            }
                          },
                          "children": [
                            {
                              "type": "img",
                              "props": {
                                "style": {
                                  "width": "100%",
                                  "height": "auto",
                                  "display": "block"
                                },
                                "src": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/next.png",
                                "alt": "Next"
                              }
                            }
                          ],
                          "onClick": "let TPI = game.data.Scoreboard.turnPlayerIndex + 1; for(let i = 0; i < game.turn.totalPlayers; i++){ if(!game.data.Scoreboard.players[TPI % game.turn.totalPlayers].passed){ game.data.Scoreboard.turnPlayerIndex = TPI; break; } TPI++; }; chatLog('has ended their action.')"
                        },
                        {
                          "type": "button",
                          "props": {
                            "className": "{{ game.data.Controls.passed ? 'disabled ' : '' }}",
                            "style": {
                              "width": "5vh",
                              "height": "5vh",
                              "background": "none",
                              "border": "none",
                              "padding": "0",
                              "cursor": "pointer",
                              "outline": "none"
                            }
                          },
                          "children": [
                            {
                              "type": "img",
                              "props": {
                                "style": {
                                  "width": "100%",
                                  "height": "auto",
                                  "display": "block"
                                },
                                "src": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/pass.png",
                                "alt": "Pass"
                              }
                            }
                          ],
                          "onClick": "game.data.Controls.passed = true; let TPI = game.data.Scoreboard.turnPlayerIndex + 1; for(let i = 0; i < game.turn.totalPlayers; i++){ if(!game.data.Scoreboard.players[TPI % game.turn.totalPlayers].passed){ game.data.Scoreboard.turnPlayerIndex = TPI; break; } TPI++; }; chatLog('has passed.')"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            "defaultValue": {
              "health": 0,
              "tokens": 0,
              "passed": false
            },
            "events": {
              "onStart": "console.log('Controls: onStart', game); console.log(game);",
              "onUpdate": "console.log('Scoreboard: onUpdate'); const gc = game.data.Controls; game.data.Scoreboard.players[game.turn.orderPosition].health = +gc.health; game.data.Scoreboard.players[game.turn.orderPosition].tokens = +gc.tokens; game.data.Scoreboard.players[game.turn.orderPosition].passed = !!gc.passed; console.log(game);",
              "onOpponentUpdate": "console.log('Controls: onOpponentUpdate', game, opponentGame); const ogc = opponentGame.data.Controls; game.data.Scoreboard.players[opponentGame.turn.orderPosition].health = +ogc.health; game.data.Scoreboard.players[opponentGame.turn.orderPosition].tokens = +ogc.tokens; game.data.Scoreboard.players[opponentGame.turn.orderPosition].passed = !!ogc.passed;",
              "onNewTurn": "console.log('Controls: onNewTurn', game); console.log(game);"
            }
          }
        }
      }
    }
  }
}