{
  "name": "Cataclysm Arcade",
  "menuBackgroundImage": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/background.jpg",
  "defaultRessources": {
    "backgrounds": [
      "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/playmat.webp"
    ],
    "decksUrl": "https://balbi.github.io/TCGA-Cataclysm-Arcade/CataclysmArcade_Decks.json"
  },
  "customHelp": "",
  "cardRotation": "90",
  "cards": {
    "dataUrl": "https://balbi.github.io/TCGA-Cataclysm-Arcade/CataclysmArcade_Cards.json",
    "cardBack": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/cardback.png"
  },
  "deckBuilding": {
    "mainFilters": [
      "type",
      "Subtype",
      "Faction",
      "Set",
      "Level",
      "Health",
      "Attack",
      "AttackCost",
      "WeaponLevel",
      "WeaponWieldCost",
      "WeaponAttackCost",
      "Rarity"
    ],
    "formats": [
      {
        "title": "Constructed",
        "gameplay": "Standard",
        "deckRuleset": "Constructed",
        "customCategories": [
          "Boss"
        ]
      }
    ],
    "deckRulesets": {
      "Constructed": {
        "reversedLegality": true,
        "general": {
          "min": 41,
          "maxPerCard": 3
        },
        "categories": [
          {
            "category": "Boss",
            "min": 1,
            "max": 1
          }
        ]
      }
    }
  },
  "gameplay": {
    "Standard": {
      "beforeGameStart": {
        "chooseAnotherStartingPlayer": true
      },
      "mulligan": {
        "triggeredByButton": true,
        "startingHandSize": 4,
        "mulliganCount": {
          "min": 0,
          "max": 1
        },
        "mulliganCycle": {
          "info": "Set aside any number of cards in your initial hand, draw that many, then shuffle the set aside cards into your deck.",
          "steps": [
            "toBottom",
            "draw",
            "shuffle"
          ],
          "selectionRange": {
            "min": 0,
            "max": 4
          },
          "keepCardsOrder": true
        }
      },
      "newTurn": {
        "drawOnStart": false,
        "sharedTurn": false,
        "firstPlayerTokenName": "",
        "drawPerTurn": "0"
      },
      "tokens": [],
      "countersStartingValues": [
        0
      ],
      "hideFacedDownCards": false,
      "sections": {
        "layout": {
          "direction": "row",
          "isSymetricalForOpponents": false,
          "style": {
            "marginTop": "10vh"
          },
          "content": [
            {
              "section": "Battlefield"
            },
            {
              "section": "Boss",
              "style": {
                "width": "22vh"
              }
            },
            {
              "section": "Battlefield2"
            }
          ]
        },
        "categoriesAlreadyOnBoard": [
          "Boss"
        ],
        "autoPlayFromHand": {},
        "autoPlayFromStack": {},
        "sectionsDict": {
          "Boss": {
            "isHidden": "no",
            "height": "MEDIUM",
            "alignment": "CENTER",
            "opponentAlignment": false,
            "noAutoPayTo": "true",
            "isHorizontalAllowed": false,
            "enterTapped": false,
            "enterSpun": false,
            "isGroupForbidden": false,
            "keepTappedNewTurn": false,
            "showHiddenCardInHistory": false,
            "noQuickActions": true
          },
          "Battlefield": {
            "isHidden": "no",
            "height": "MEDIUM",
            "alignment": "CENTER",
            "opponentAlignment": false,
            "noAutoPayTo": true,
            "isHorizontalAllowed": false,
            "noQuickActions": true,
            "enterTapped": false,
            "enterSpun": false,
            "isGroupForbidden": false,
            "keepTappedNewTurn": false,
            "showHiddenCardInHistory": false
          },
          "Battlefield2": {
            "isHidden": "no",
            "height": "MEDIUM",
            "alignment": "CENTER",
            "opponentAlignment": false,
            "noAutoPayTo": true,
            "isHorizontalAllowed": false,
            "noQuickActions": true,
            "enterTapped": false,
            "enterSpun": false,
            "isGroupForbidden": false,
            "keepTappedNewTurn": false,
            "showHiddenCardInHistory": false
          },
          "Gigs": {
            "type": "custom",
            "isShared": true,
            "blueprint": {
              "type": "div",
              "props": {
                "className": "d-flex flex-column justify-content-between position-fixed start-50 top-50 translate-middle",
                "style": {
                  "--gigs-width": "7vh",
                  "--gigs-font-weight": "700",
                  "--gigs-font-size": "1.7vh",
                  "--gigs-blue": "#64bfe3",
                  "--gigs-red": "#d83938",
                  "--gigs-opacity": "0.3",
                  "--gigs-padding": "0.7vh 0",
                  "--input-color-empty": "transparent",
                  "height": "10vh",
                  "width": "115vh",
                  "backdropFilter": "blur(20px)",
                  "padding": "0.5vh",
                  "backgroundColor": "#202020c9",
                  "borderRadius": "0.5vh",
                  "marginLeft": "var(--left-offset-centered)"
                }
              },
              "children": [
                {
                  "type": "div",
                  "props": {
                    "className": "d-flex gap-3"
                  },
                  "children": [
                    {
                      "type": "div",
                      "props": {
                        "className": "d-flex ",
                        "style": {
                          "marginRight": "auto"
                        }
                      },
                      "children": [
                        {
                          "type": "loop",
                          "iterable": "game.data.OppGigs.dices",
                          "template": {
                            "type": "div",
                            "props": {
                              "className": "position-relative on-section-hovered",
                              "style": {
                                "width": "var(--gigs-width)",
                                "pointerEvents": "{{item.stolen || item.value === 0 ? 'none' : 'auto'}}"
                              }
                            },
                            "children": [
                              {
                                "type": "input-number",
                                "props": {
                                  "value": "{{item.value}}",
                                  "readOnly": true,
                                  "type": "number",
                                  "style": {
                                    "backgroundColor": "transparent",
                                    "background": "url(https://russeus.github.io/CyberpunkTCG-TCGA/Images/Blue/d{{item.dice}}.png) center / contain no-repeat",
                                    "textAlign": "center",
                                    "--input-color": "{{item.stolen ? 'transparent' : 'var(--gigs-blue)'}}",
                                    "opacity": "{{item.stolen ? 'var(--gigs-opacity)' : '1'}}",
                                    "fontSize": "var(--gigs-font-size)",
                                    "fontWeight": "var(--gigs-font-weight)",
                                    "padding": "var(--gigs-padding)"
                                  }
                                }
                              },
                              {
                                "type": "button",
                                "props": {
                                  "className": "hovered-reveal position-absolute top-100 start-50",
                                  "style": {
                                    "translate": "-50% -10%",
                                    "zIndex": 1
                                  }
                                },
                                "children": "Steal",
                                "onClick": "game.data.OppGigs.dices[index].stolen = true"
                              }
                            ]
                          }
                        }
                      ]
                    },
                    {
                      "type": "div",
                      "props": {
                        "className": "d-flex ",
                        "style": {
                          "marginLeft": "auto"
                        }
                      },
                      "children": [
                        {
                          "type": "loop",
                          "iterable": "game.data.MyGigs.dices",
                          "template": {
                            "type": "div",
                            "props": {
                              "className": "position-relative on-section-hovered",
                              "style": {
                                "width": "var(--gigs-width)",
                                "pointerEvents": "{{item.stolen && item.value !== 0 ? 'auto' : 'none'}}"
                              }
                            },
                            "children": [
                              {
                                "type": "input-number",
                                "props": {
                                  "value": "{{item.value}}",
                                  "type": "number",
                                  "readOnly": true,
                                  "style": {
                                    "backgroundColor": "transparent",
                                    "background": "url(https://russeus.github.io/CyberpunkTCG-TCGA/Images/Red/d{{item.dice}}.png) center / contain no-repeat",
                                    "textAlign": "center",
                                    "--input-color": "{{item.stolen ? 'var(--gigs-red)' : 'transparent'}}",
                                    "opacity": "{{item.stolen ? '1' : 'var(--gigs-opacity)'}}",
                                    "fontSize": "var(--gigs-font-size)",
                                    "fontWeight": "var(--gigs-font-weight)",
                                    "padding": "var(--gigs-padding)"
                                  }
                                }
                              },
                              {
                                "type": "button",
                                "props": {
                                  "className": "hovered-reveal position-absolute top-100 start-50",
                                  "style": {
                                    "translate": "-50% -10%",
                                    "zIndex": 1
                                  }
                                },
                                "children": "Steal",
                                "onClick": "game.data.MyGigs.dices[index].stolen = false"
                              }
                            ]
                          }
                        }
                      ]
                    },
                    {
                      "type": "div",
                      "props": {
                        "className": "d-flex align-items-center justify-content-center",
                        "style": {
                          "color": "var(--gigs-red)",
                          "fontSize": "var(--gigs-font-size)",
                          "fontWeight": "var(--gigs-font-weight)",
                          "width": "var(--gigs-width)"
                        }
                      },
                      "children": "{{game.data.Totals.opp}}"
                    }
                  ]
                },
                {
                  "type": "div",
                  "props": {
                    "className": "d-flex gap-3"
                  },
                  "children": [
                    {
                      "type": "div",
                      "props": {
                        "className": "d-flex ",
                        "style": {
                          "marginRight": "auto"
                        }
                      },
                      "children": [
                        {
                          "type": "loop",
                          "iterable": "game.data.OppGigs.dices",
                          "template": {
                            "type": "div",
                            "props": {
                              "className": "position-relative on-section-hovered",
                              "style": {
                                "width": "var(--gigs-width)",
                                "pointerEvents": "{{item.stolen ? 'auto' : 'none'}}"
                              }
                            },
                            "children": [
                              {
                                "type": "input-number",
                                "props": {
                                  "value": "{{item.value}}",
                                  "type": "number",
                                  "style": {
                                    "backgroundColor": "transparent",
                                    "background": "url(https://russeus.github.io/CyberpunkTCG-TCGA/Images/Red/d{{item.dice}}.png) center / contain no-repeat",
                                    "textAlign": "center",
                                    "--input-color": "{{item.stolen ? 'var(--gigs-red)' : 'transparent'}}",
                                    "opacity": "{{item.stolen ? '1' : 'var(--gigs-opacity)'}}",
                                    "fontSize": "var(--gigs-font-size)",
                                    "fontWeight": "var(--gigs-font-weight)",
                                    "padding": "var(--gigs-padding)"
                                  }
                                },
                                "onChange": "game.data.OppGigs.dices[index].value = value; chatLog('changed dice to ' + value + `/` + item.dice)"
                              },
                              {
                                "type": "button",
                                "props": {
                                  "className": "hovered-reveal position-absolute top-0 start-50",
                                  "style": {
                                    "translate": "-50% -90%"
                                  }
                                },
                                "children": "Roll",
                                "onClick": "game.data.OppGigs.dices[index].value = Math.floor(Math.random() * game.data.OppGigs.dices[index].dice) + 1; game.data.MyGigs.hasRolled = true; chatLog(`rolled ` + game.data.OppGigs.dices[index].value + '/' + game.data.OppGigs.dices[index].dice)"
                              }
                            ]
                          }
                        }
                      ]
                    },
                    {
                      "type": "div",
                      "props": {
                        "className": "position-relative h-100"
                      },
                      "children": [
                        {
                          "type": "div",
                          "props": {
                            "className": "box-container position-absolute start-50 top-50 translate-middle text-nowrap m-0",
                            "style": {
                              "opacity": "{{game.turn.isMyTurn && !game.data.MyGigs.hasRolled ? 1 : 0}}"
                            }
                          },
                          "children": "Don't forget to roll!"
                        }
                      ]
                    },
                    {
                      "type": "div",
                      "props": {
                        "className": "d-flex ",
                        "style": {
                          "marginLeft": "auto"
                        }
                      },
                      "children": [
                        {
                          "type": "loop",
                          "iterable": "game.data.MyGigs.dices",
                          "template": {
                            "type": "div",
                            "props": {
                              "className": "position-relative on-section-hovered",
                              "style": {
                                "width": "var(--gigs-width)",
                                "pointerEvents": "{{item.stolen ? 'none' : 'auto'}}"
                              }
                            },
                            "children": [
                              {
                                "type": "input-number",
                                "props": {
                                  "value": "{{item.value}}",
                                  "type": "number",
                                  "style": {
                                    "backgroundColor": "transparent",
                                    "background": "url(https://russeus.github.io/CyberpunkTCG-TCGA/Images/Blue/d{{item.dice}}.png) center / contain no-repeat",
                                    "textAlign": "center",
                                    "--input-color": "{{item.stolen ? 'transparent' : 'var(--gigs-blue)'}}",
                                    "opacity": "{{item.stolen ? 'var(--gigs-opacity)' : '1'}}",
                                    "fontSize": "var(--gigs-font-size)",
                                    "fontWeight": "var(--gigs-font-weight)",
                                    "padding": "var(--gigs-padding)"
                                  }
                                },
                                "onChange": "game.data.MyGigs.dices[index].value = value; chatLog('changed dice to ' + value + `/` + item.dice)"
                              },
                              {
                                "type": "button",
                                "props": {
                                  "className": "hovered-reveal position-absolute top-0 start-50",
                                  "style": {
                                    "translate": "-50% -90%"
                                  }
                                },
                                "children": "Roll",
                                "onClick": "game.data.MyGigs.dices[index].value = Math.floor(Math.random() * game.data.MyGigs.dices[index].dice) + 1; game.data.MyGigs.hasRolled = true; chatLog(`rolled ` + game.data.MyGigs.dices[index].value + '/' + game.data.OppGigs.dices[index].dice)"
                              }
                            ]
                          }
                        }
                      ]
                    },
                    {
                      "type": "div",
                      "props": {
                        "className": "d-flex align-items-center justify-content-center",
                        "style": {
                          "color": "var(--gigs-blue)",
                          "fontSize": "var(--gigs-font-size)",
                          "fontWeight": "var(--gigs-font-weight)",
                          "width": "var(--gigs-width)"
                        }
                      },
                      "children": "{{game.data.Totals.my}}"
                    }
                  ]
                }
              ]
            }
          }
        }
      }
    }
  }
}