{
  "name": "Cataclysm Arcade Dev",
  "menuBackgroundImage": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/background.jpg",
  "defaultRessources": {
    "backgrounds": [
      "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/playmat.webp",
      "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/playmat2.webp"
    ],
    "decksUrl": "https://balbi.github.io/TCGA-Cataclysm-Arcade/CataclysmArcade_Decks.json"
  },
  "customHelp": "",
  "cardRotation": "90",
  "cards": {
    "dataUrl": "https://balbi.github.io/TCGA-Cataclysm-Arcade/CataclysmArcade_Cards.json",
    "cardBack": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/cardback.png"
  },
  "deckBuilding": {
    "mainFilters": [
      "type",
      "Subtype",
      "Faction",
      "Set",
      "Level",
      "Health",
      "Attack",
      "AttackCost",
      "WeaponLevel",
      "WeaponWieldCost",
      "WeaponAttackCost",
      "Rarity"
    ],
    "formats": [
      {
        "title": "Constructed",
        "gameplay": "Standard",
        "deckRuleset": "Constructed",
        "customCategories": [
          "Boss"
        ]
      }
    ],
    "deckRulesets": {
      "Constructed": {
        "reversedLegality": true,
        "general": {
          "min": 41,
          "maxPerCard": 3
        },
        "categories": [
          {
            "category": "Boss",
            "min": 1,
            "max": 1
          }
        ]
      }
    }
  },
  "gameplay": {
    "Standard": {
      "mulligan": {
        "triggeredByButton": true,
        "startingHandSize": 4,
        "mulliganCount": {
          "min": 0,
          "max": 1
        },
        "mulliganCycle": {
          "info": "Choose any number of cards to be redrawn. Your deck will automatically be shuffled when completed.",
          "steps": [
            "toBottom",
            "draw",
            "shuffle"
          ],
          "selectionRange": {
            "min": 0,
            "max": 4
          },
          "keepCardsOrder": true
        }
      },
      "newTurn": {
        "drawOnStart": true,
        "sharedTurn": true,
        "firstPlayerTokenName": "",
        "drawPerTurn": "1"
      },
      "tokens": [],
      "countersStartingValues": [],
      "hideFacedDownCards": false,
      "draggableTokens": [
        {
          "id": "attack_plus",
          "name": "+Attack",
          "image": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/tokens/token_attack_plus.png"
        },
        {
          "id": "attack_minus",
          "name": "-Attack",
          "image": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/tokens/token_attack_minus.png"
        },
        {
          "id":"health_plus",
          "name": "+Health",
          "image": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/tokens/token_health_plus.png"
        },
        {
          "id":"health_minus",
          "name": "-Health",
          "image": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/tokens/token_health_minus.png"
        },
        {
          "id": "stun",
          "name": "Stun",
          "image": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/tokens/token_stun.png"
        },
        {
          "id": "marker",
          "name": "Marker",
          "image": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/token_blank.png"
        }
      ],
      "sections": {
        "layout": {
          "direction": "column",
          "isSymetricalForOpponents": false,
          "style": {
            "marginTop": "2vh"
          },
          "content": [
            {
              "section": "Scoreboard"
            },
            {
              "section": "PlayerData"
            },
            {
              "direction": "row",
              "isSymetricalForOpponents": false,
              "style": {
                "justify-content": "center",
                "padding": "0 20vh"
              },
              "content": [
                {
                  "section": "Boss",
                  "style": {
                    "width": "16vh"
                  }
                },
                {
                  "section": "Controls"
                }
              ]
            },
            {
              "section": "Battlefield"
            }
          ]
        },
        "categoriesAlreadyOnBoard": [
          "Boss"
        ],
        "autoPlayFromHand": {},
        "autoPlayFromStack": {},
        "sectionsDict": {
          "Boss": {
            "isHidden": "no",
            "height": "MEDIUM",
            "alignment": "CENTER",
            "opponentAlignment": false,
            "noAutoPayTo": "true",
            "isHorizontalAllowed": false,
            "enterTapped": false,
            "enterSpun": false,
            "isGroupForbidden": false,
            "keepTappedNewTurn": false,
            "showHiddenCardInHistory": false,
            "noQuickActions": true
          },
          "Battlefield": {
            "isHidden": "no",
            "height": "SMALL",
            "alignment": "CENTER",
            "opponentAlignment": false,
            "noAutoPayTo": true,
            "isHorizontalAllowed": false,
            "noQuickActions": true,
            "enterTapped": false,
            "enterSpun": false,
            "isGroupForbidden": false,
            "keepTappedNewTurn": false,
            "showHiddenCardInHistory": false
          },
          "TurnData": {
            "type": "custom",
            "isShared": true,
            "defaultValue": {
              "level": 1,
              "turnPlayerIndex": -1,
              "roundPlayerIndex": -1
            },
            "events": {
              "onStart": "console.log('TurnData: onStart', game);if(game.turn.orderPosition == 0){ let firstTurnPlayer = Math.floor(Math.random() * game.turn.totalPlayers) - 1; game.data.TurnData.roundPlayerIndex = firstTurnPlayer; chatLog('Player ' + (firstTurnPlayer + 2) + ' will go first.'); }",
              "onNewTurn": "console.log('TurnData: onNewTurn', game); game.data.TurnData.level = Math.min(Math.max(game.turn.count, 1), 9); game.data.TurnData.roundPlayerIndex = (game.data.TurnData.roundPlayerIndex + 1) % game.turn.totalPlayers; game.data.TurnData.turnPlayerIndex = game.data.TurnData.roundPlayerIndex; for(const player of game.data.PlayerData.players){ player.tokens = game.data.TurnData.level; player.passed = false; };",
              "onOpponentUpdate": "console.log('TurnData: onOpponentUpdate', 'game', game, 'opponentGame', opponentGame, 'delta', delta, 'self', self); const ogt = opponentGame.data.TurnData; Object.assign(game.data.TurnData, { level: ogt.level, turnPlayerIndex: ogt.turnPlayerIndex, roundPlayerIndex: ogt.roundPlayerIndex });"
            }
          },
          "PlayerData": {
            "type": "custom",
            "isShared": true,
            "defaultValue": {
              "players": [
                {
                  "health": 16,
                  "tokens": 0,
                  "passed": false,
                  "index": 0
                },
                {
                  "health": 16,
                  "tokens": 0,
                  "passed": false,
                  "index": 1
                },
                {
                  "health": 16,
                  "tokens": 0,
                  "passed": false,
                  "index": 2
                },
                {
                  "health": 16,
                  "tokens": 0,
                  "passed": false,
                  "index": 3
                }
              ]
            },
            "events": {
              "onOpponentUpdate": "console.log('PlayerData: onOpponentUpdate', 'game', game, 'opponentGame', opponentGame, 'delta', delta, 'self', self); const ogp = opponentGame.data.PlayerData.players[opponentGame.turn.orderPosition]; Object.assign(game.data.PlayerData.players[ogp.index], { health: ogp.health, tokens: ogp.tokens, passed: ogp.passed });"
            }
          },
          "Scoreboard": {
            "type": "custom",
            "playerRenderOnly": true,
            "blueprint": {
              "type": "div",
              "props": {
                "className": "flex-row justify-content-between position-fixed start-50 top-50 translate-middle",
                "style": {
                  "--scoreboard-width": "7vh",
                  "--scoreboard-font-weight": "900",
                  "--scoreboard-font-size": "1.7vh",
                  "--scoreboard-blue": "#64bfe3",
                  "--scoreboard-red": "#d83938",
                  "--scoreboard-opacity": "0.3",
                  "--scoreboard-padding": "0.7vh 0",
                  "--input-color-empty": "transparent",
                  "height": "7vh",
                  "backdropFilter": "blur(20px)",
                  "padding": "0.5vh",
                  "backgroundColor": "#202020c9",
                  "borderRadius": "0.5vh",
                  "marginLeft": "var(--left-offset-centered)",
                  "display": "{{ game.turn.count > 0 ? 'flex' : 'none' }}"
                }
              },
              "children": [
                {
                  "type": "img",
                  "props": {
                    "style": {
                      "height": "100%"
                    },
                    "src": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/level_{{ Math.max(game.data.TurnData.level, 1) }}.png"
                  }
                },
                {
                  "type": "loop",
                  "iterable": "game.data.PlayerData.players",
                  "template": {
                    "type": "div",
                    "props": {
                      "className": "flex-column justify-content-between",
                      "style": {
                        "height": "100%",
                        "padding": "0 1vh",
                        "display": "{{ item.index < game.turn.totalPlayers ? 'flex' : 'none' }}"
                      }
                    },
                    "children": [
                      {
                        "type": "div",
                        "props": {
                          "style": {
                            "font-weight": "bold",
                            "text-shadow":"-1px -1px 0 #000, 1px -1px 0 #000,-1px  1px 0 #000, 1px  1px 0 #000"
                          }
                        },
                        "children": "{{ game.turn.orderPosition == item.index ? 'You' : 'Player ' + (item.index + 1)}}"
                      },
                      {
                        "type": "div",
                        "props": {
                          "className": "d-flex flex-row justify-content-around",
                          "style": {
                            "height": "3vh",
                            "width": "12vh"
                          }
                        },
                        "children": [
                          {
                            "type": "div",
                            "props": {
                              "style": {
                                "position": "relative",
                                "height": "100%",
                                "width": "3vh"
                              }
                            },
                            "children": [
                              {
                                "type": "img",
                                "props": {
                                  "style": {
                                    "height": "100%"
                                  },
                                  "src": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/health_blank.png"
                                }
                              },
                              {
                                "type": "div",
                                "props": {
                                  "style": {
                                    "top": "0.075vh",
                                    "position": "absolute",
                                    "height": "100%",
                                    "width": "100%",
                                    "color": "white",
                                    "font-weight": "bold",
                                    "display": "flex",
                                    "align-items": "center",
                                    "justify-content": "center"
                                  }
                                },
                                "children": [
                                  {
                                    "type": "span",
                                    "props": {
                                      "style": {
                                        "text-shadow": "-1px -1px 0 #000, 1px -1px 0 #000,-1px  1px 0 #000, 1px  1px 0 #000",
                                        "font-size": "2.25vh"
                                      }
                                    },
                                    "children": "{{ Math.max(game.data.PlayerData.players[item.index].health, 0) }}"
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "type": "div",
                            "props": {
                              "style": {
                                "position": "relative",
                                "height": "100%",
                                "width": "3vh"
                              }
                            },
                            "children": [
                              {
                                "type": "img",
                                "props": {
                                  "style": {
                                    "height": "100%"
                                  },
                                  "src": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/token_blank.png"
                                }
                              },
                              {
                                "type": "div",
                                "props": {
                                  "style": {
                                    "top": "0.075vh",
                                    "position": "absolute",
                                    "height": "100%",
                                    "width": "100%",
                                    "color": "white",
                                    "font-weight": "bold",
                                    "display": "flex",
                                    "align-items": "center",
                                    "justify-content": "center"
                                  }
                                },
                                "children": [
                                  {
                                    "type": "span",
                                    "props": {
                                      "style": {
                                        "text-shadow": "-1px -1px 0 #000, 1px -1px 0 #000,-1px  1px 0 #000, 1px  1px 0 #000",
                                        "font-size": "2.25vh"
                                      }
                                    },
                                    "children": "{{ Math.max(game.data.PlayerData.players[item.index].tokens, 0) }}"
                                  }
                                ]
                              }
                            ]
                          },
                          {
                            "type": "img",
                            "props": {
                              "style": {
                                "height": "100%"
                              },
                              "src": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/{{ game.data.PlayerData.players[item.index].passed ? 'red' : 'green' }}.png"
                            }
                          }
                        ]
                      }
                    ]
                  }
                }
              ]
            }
          },
          "Controls": {
            "type": "custom",
            "playerRenderOnly": true,
            "blueprint": {
              "type": "div",
              "props": {
                "className": "controls",
                "style": {
                  "display": "{{ game.turn.count > 0 ? 'block' : 'none' }}"
                }
              },
              "children": [
                {
                  "type": "div",
                  "props": {
                    "className": "flex-column justify-content-right position-fixed top-50",
                    "style": {
                      "--scoreboard-width": "6vh",
                      "--scoreboard-font-weight": "700",
                      "--scoreboard-font-size": "1.7vh",
                      "--scoreboard-opacity": "0.3",
                      "--scoreboard-padding": "0.7vh 0",
                      "--input-color-empty": "transparent",
                      "width": "16vh",
                      "height": "20vh",
                      "right": "31.5vh",
                      "backdropFilter": "blur(20px)",
                      "padding": "1.5vh",
                      "backgroundColor": "#202020c9",
                      "borderRadius": "0.5vh"
                    }
                  },
                  "children": [
                    {
                      "type": "h4",
                      "props": {
                        "style": {
                          "visibility": "{{ game.data.TurnData.turnPlayerIndex == game.turn.orderPosition ? 'visible' : 'hidden' }}"
                        }
                      },
                      "children": [
                        "Your Turn!"
                      ]
                    },
                    {
                      "type": "div",
                      "props": {
                        "className": "d-flex flex-row justify-content-center"
                      },
                      "children": [
                        {
                          "type": "h4",
                          "children": [
                            "Health"
                          ]
                        },
                        {
                          "type": "input-number",
                          "props": {
                            "value": "{{ game.data.PlayerData.players[game.turn.orderPosition].health }}",
                            "type": "number",
                            "style": {
                              "width": "4vh",
                              "textAlign": "center"
                            }
                          },
                          "onChange": "game.data.PlayerData.players[game.turn.orderPosition].health = +value; chatLog('has updated their health to ' + value)"
                        }
                      ]
                    },
                    {
                      "type": "div",
                      "props": {
                        "className": "d-flex flex-row justify-content-center"
                      },
                      "children": [
                        {
                          "type": "h4",
                          "children": [
                            "Tokens"
                          ]
                        },
                        {
                          "type": "input-number",
                          "props": {
                            "value": "{{ game.data.PlayerData.players[game.turn.orderPosition].tokens }}",
                            "type": "number",
                            "style": {
                              "width": "4vh",
                              "textAlign": "center"
                            }
                          },
                          "onChange": "game.data.PlayerData.players[game.turn.orderPosition].tokens = Math.max(+value,0); chatLog('has updated their tokens to ' + value)"
                        }
                      ]
                    },
                    {
                      "type": "div",
                      "props": {
                        "className": "d-flex flex-row justify-content-around"
                      },
                      "children": [
                        {
                          "type": "button",
                          "props": {
                            "className": "{{ (game.data.TurnData.turnPlayerIndex != game.turn.orderPosition) || (game.data.PlayerData.players.filter(p => p.index != game.turn.orderPosition).every(player => player.passed)) || game.data.PlayerData.players[game.turn.orderPosition].passed ? 'disabled ' : '' }}",
                            "style": {
                              "width": "5vh",
                              "height": "5vh",
                              "background": "none",
                              "border": "none",
                              "padding": "0",
                              "cursor": "pointer",
                              "outline": "none"
                            }
                          },
                          "children": [
                            {
                              "type": "img",
                              "props": {
                                "style": {
                                  "width": "100%",
                                  "height": "auto",
                                  "display": "block"
                                },
                                "src": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/next.png",
                                "alt": "Next"
                              }
                            }
                          ],
                          "onClick": "if(!game.data.PlayerData.players.filter(p => p.index != game.turn.orderPosition).every(player => player.passed)){ for(let i = game.turn.orderPosition + 1; i < game.turn.orderPosition + 4; i++){ if(!game.data.PlayerData.players[i % game.turn.totalPlayers].passed){ game.data.TurnData.turnPlayerIndex = i % game.turn.totalPlayers; break; } } }; chatLog('has ended their action.')"
                        },
                        {
                          "type": "button",
                          "props": {
                            "className": "{{ game.data.PlayerData.players[game.turn.orderPosition].passed ? 'disabled ' : '' }}",
                            "style": {
                              "width": "5vh",
                              "height": "5vh",
                              "background": "none",
                              "border": "none",
                              "padding": "0",
                              "cursor": "pointer",
                              "outline": "none"
                            }
                          },
                          "children": [
                            {
                              "type": "img",
                              "props": {
                                "style": {
                                  "width": "100%",
                                  "height": "auto",
                                  "display": "block"
                                },
                                "src": "https://balbi.github.io/TCGA-Cataclysm-Arcade/images/scoreboard/pass.png",
                                "alt": "Pass"
                              }
                            }
                          ],
                          "onClick": "game.data.PlayerData.players[game.turn.orderPosition].passed = true; if(!game.data.PlayerData.players.filter(p => p.index != game.turn.orderPosition).every(player => player.passed)){ for(let i = game.turn.orderPosition + 1; i < game.turn.orderPosition + 4; i++){ if(!game.data.PlayerData.players[i % game.turn.totalPlayers].passed){ game.data.TurnData.turnPlayerIndex = i % game.turn.totalPlayers; break; } } }; chatLog('has passed.')"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          }
        }
      }
    }
  }
}